{
  "name": "pi-nvidia-adapter",
  "version": "0.0.4",
  "description": "NVIDIA API provider adapter for pi coding agent — dynamically auto-discover models via models.dev",
  "type": "module",
  "files": [
    "index.ts",
    "src/generated/models.json",
    "README.md"
  ],
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "update-models": "bun scripts/update-models.ts",
    "backup-models": "bun scripts/backup-models.ts"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
